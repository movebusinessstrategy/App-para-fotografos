import React, { useState, useRef, useCallback } from "react";
import {
  Upload, Film, Mic, Brain, CheckCircle, Loader2, AlertCircle,
  Play, Download, Edit2, X, ChevronRight, Scissors, ZoomIn,
  MessageSquare, Music, Settings2, ChevronDown, ChevronUp, History,
} from "lucide-react";

// On Vercel the 4.5 MB proxy limit breaks video uploads — call Render directly
const isLocal = typeof window !== "undefined" &&
  (window.location.hostname === "localhost" || window.location.hostname === "127.0.0.1");
const RENDER_ORIGIN = "https://app-para-fotografos.onrender.com";
const API_BASE = isLocal ? "/api/video-editor" : `${RENDER_ORIGIN}/api/video-editor`;

// Warm up Render free tier on module load (runs once, fire-and-forget)
if (!isLocal) {
  fetch(`${RENDER_ORIGIN}/api/health`).catch(() => {});
}

// ─── Types ─────────────────────────────────────────────────────────────────

interface Scene {
  id: number;
  type: "A" | "B" | "C" | "D" | "E" | "F" | "G" | "H" | "I";
  startLeg: number;
  title: string;
  subtitle?: string;
  icon?: string;
  duration: number;
}

interface ColorPalette {
  primary: string; secondary: string; accent: string; background: string;
}

interface Analysis {
  narrativeFormat: string;
  colorPalette: ColorPalette;
  scenes: Scene[];
}

interface EffectsConfig {
  silenceCut: { enabled: boolean; gap: number; pad: number };
  zoom:       { enabled: boolean; intensity: number };
  captions:   { enabled: boolean; fontSize: number; color: string; position: "top" | "middle" | "bottom" };
  music:      { enabled: boolean; volume: number };
}

const DEFAULT_EFFECTS: EffectsConfig = {
  silenceCut: { enabled: true,  gap: 0.5,  pad: 0.2 },
  zoom:       { enabled: false, intensity: 0.05 },
  captions:   { enabled: false, fontSize: 30, color: "#FFFFFF", position: "bottom" },
  music:      { enabled: false, volume: 15 },
};

type Step = "upload" | "processing" | "review";
type ProcessingStepId = "normalize" | "transcribe" | "analyze";
type ProcessingStatus  = "pending" | "loading" | "done" | "error";

interface ProcessingStep {
  id: ProcessingStepId;
  label: string;
  icon: React.ElementType;
  status: ProcessingStatus;
  error?: string;
  percent?: number;
}

const SCENE_TYPE_LABELS: Record<Scene["type"], string> = {
  A: "Frase de Impacto", B: "Apresentação",      C: "Painel Superior",
  D: "Comparativo",      E: "Card Numerado",      F: "Estilo WhatsApp",
  G: "Número em Destaque", H: "Fluxo de Passos", I: "Call to Action",
};

const NARRATIVE_FORMAT_LABELS: Record<string, string> = {
  educativo: "Educativo", storytelling: "Storytelling", lista: "Lista",
  comparativo: "Comparativo", cta: "CTA", tutorial: "Tutorial", depoimento: "Depoimento",
};

// ─── Sub-components ────────────────────────────────────────────────────────

function SceneTypeBadge({ type }: { type: Scene["type"] }) {
  const colors: Record<Scene["type"], string> = {
    A: "bg-purple-100 text-purple-700 dark:bg-purple-500/20 dark:text-purple-300",
    B: "bg-blue-100 text-blue-700 dark:bg-blue-500/20 dark:text-blue-300",
    C: "bg-cyan-100 text-cyan-700 dark:bg-cyan-500/20 dark:text-cyan-300",
    D: "bg-orange-100 text-orange-700 dark:bg-orange-500/20 dark:text-orange-300",
    E: "bg-green-100 text-green-700 dark:bg-green-500/20 dark:text-green-300",
    F: "bg-teal-100 text-teal-700 dark:bg-teal-500/20 dark:text-teal-300",
    G: "bg-yellow-100 text-yellow-700 dark:bg-yellow-500/20 dark:text-yellow-300",
    H: "bg-pink-100 text-pink-700 dark:bg-pink-500/20 dark:text-pink-300",
    I: "bg-indigo-100 text-indigo-700 dark:bg-indigo-500/20 dark:text-indigo-300",
  };
  return (
    <span className={`inline-flex items-center gap-1 px-2 py-0.5 rounded-lg text-xs font-semibold ${colors[type]}`}>
      <span className="font-bold">{type}</span>
      <span>{SCENE_TYPE_LABELS[type]}</span>
    </span>
  );
}

function ProcessingStepItem({ step }: { step: ProcessingStep }) {
  return (
    <div className="flex items-center gap-4 p-4 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900">
      <div className={`w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 ${
        step.status === "done"    ? "bg-green-100 dark:bg-green-500/20 text-green-600 dark:text-green-400"
        : step.status === "loading" ? "bg-indigo-100 dark:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400"
        : step.status === "error"   ? "bg-red-100 dark:bg-red-500/20 text-red-600 dark:text-red-400"
        : "bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-600"}`}>
        {step.status === "loading" ? <Loader2 size={20} className="animate-spin" />
          : step.status === "done"  ? <CheckCircle size={20} />
          : step.status === "error" ? <AlertCircle size={20} />
          : <step.icon size={20} />}
      </div>
      <div className="flex-1 min-w-0">
        <div className="flex items-center justify-between gap-2">
          <p className={`text-sm font-medium ${step.status === "pending" ? "text-gray-400 dark:text-gray-600" : "text-gray-900 dark:text-gray-100"}`}>
            {step.label}
          </p>
          {step.status === "loading" && step.percent !== undefined && (
            <span className="text-xs text-indigo-600 dark:text-indigo-400 font-semibold flex-shrink-0">{step.percent}%</span>
          )}
          {step.status === "done" && (
            <span className="text-xs text-green-600 dark:text-green-400 font-medium flex-shrink-0">Concluído</span>
          )}
        </div>
        {step.status === "loading" && step.percent !== undefined && (
          <div className="mt-1.5 h-1.5 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
            <div className="h-full bg-indigo-500 rounded-full transition-all duration-500" style={{ width: `${step.percent}%` }} />
          </div>
        )}
        {step.error && <p className="text-xs text-red-500 dark:text-red-400 mt-0.5 truncate">{step.error}</p>}
      </div>
    </div>
  );
}

// ─── Cut Timeline ───────────────────────────────────────────────────────────

function CutTimeline({ jobId, apiBase }: { jobId: string | null; apiBase: string }) {
  const [segs, setSegs] = React.useState<{ start: number; end: number }[]>([]);
  React.useEffect(() => {
    if (!jobId) return;
    fetch(`${apiBase}/segments/${jobId}`)
      .then(r => r.json())
      .then(data => { if (data.segments?.length) setSegs(data.segments); })
      .catch(() => {});
  }, [jobId, apiBase]);

  if (!segs.length) return null;
  const kept  = segs.reduce((a, s) => a + (s.end - s.start), 0);
  const total = segs[segs.length - 1].end + 0.5;

  return (
    <div className="space-y-1.5">
      <div className="flex items-center justify-between text-xs text-gray-500 dark:text-gray-400">
        <span>Timeline de cortes</span>
        <span className="text-green-600 dark:text-green-400 font-medium">{kept.toFixed(1)}s de {total.toFixed(1)}s aproveitados</span>
      </div>
      <div className="relative h-5 rounded-lg overflow-hidden bg-red-200 dark:bg-red-900/40">
        {segs.map((s, i) => (
          <div key={i} className="absolute h-full bg-green-400 dark:bg-green-500 rounded-sm"
            style={{ left: `${(s.start / total) * 100}%`, width: `${((s.end - s.start) / total) * 100}%` }}
            title={`${s.start.toFixed(1)}s – ${s.end.toFixed(1)}s`}
          />
        ))}
      </div>
      <div className="flex justify-between text-[10px] text-gray-400 dark:text-gray-600">
        <span>Verde = fala mantida · Vermelho = silêncio cortado</span>
        <span>{segs.length} blocos</span>
      </div>
    </div>
  );
}

// ─── Effects Panel ──────────────────────────────────────────────────────────

function Toggle({ enabled, onToggle }: { enabled: boolean; onToggle: () => void }) {
  return (
    <button onClick={onToggle} role="switch" aria-checked={enabled}
      className={`relative inline-flex h-5 w-9 items-center rounded-full transition-colors focus:outline-none ${enabled ? "bg-indigo-600" : "bg-gray-200 dark:bg-gray-700"}`}>
      <span className={`inline-block h-3.5 w-3.5 transform rounded-full bg-white shadow transition-transform ${enabled ? "translate-x-5" : "translate-x-0.5"}`} />
    </button>
  );
}

function EffectsSection({
  title, icon, enabled, onToggle, children,
}: {
  title: string; icon: React.ReactNode; enabled: boolean; onToggle: () => void; children?: React.ReactNode;
}) {
  const [open, setOpen] = React.useState(false);
  return (
    <div className={`rounded-xl border transition-colors ${enabled ? "border-indigo-200 dark:border-indigo-500/30 bg-indigo-50/50 dark:bg-indigo-500/5" : "border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900"}`}>
      <div className="flex items-center gap-3 p-4">
        <div className={`w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0 ${enabled ? "bg-indigo-100 dark:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400" : "bg-gray-100 dark:bg-gray-800 text-gray-400 dark:text-gray-500"}`}>
          {icon}
        </div>
        <span className={`flex-1 text-sm font-medium ${enabled ? "text-gray-900 dark:text-gray-100" : "text-gray-500 dark:text-gray-400"}`}>{title}</span>
        {children && (
          <button onClick={() => setOpen(o => !o)} disabled={!enabled}
            className="p-1 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 disabled:opacity-30">
            {open ? <ChevronUp size={14} /> : <ChevronDown size={14} />}
          </button>
        )}
        <Toggle enabled={enabled} onToggle={onToggle} />
      </div>
      {enabled && open && children && (
        <div className="px-4 pb-4 pt-3 space-y-3 border-t border-indigo-100 dark:border-indigo-500/20">
          {children}
        </div>
      )}
    </div>
  );
}

function SliderField({ label, value, min, max, step, format, onChange }: {
  label: string; value: number; min: number; max: number; step: number;
  format?: (v: number) => string; onChange: (v: number) => void;
}) {
  return (
    <div className="space-y-1">
      <div className="flex items-center justify-between text-xs text-gray-600 dark:text-gray-400">
        <span>{label}</span>
        <span className="font-semibold text-gray-900 dark:text-gray-100">{format ? format(value) : value}</span>
      </div>
      <input type="range" min={min} max={max} step={step} value={value}
        onChange={e => onChange(Number(e.target.value))}
        className="w-full h-1.5 bg-gray-200 dark:bg-gray-700 rounded-full appearance-none cursor-pointer accent-indigo-600"
      />
    </div>
  );
}

function EffectsPanel({ effects, onChange, musicFile, onMusicFile }: {
  effects: EffectsConfig;
  onChange: (e: EffectsConfig) => void;
  musicFile: File | null;
  onMusicFile: (f: File | null) => void;
}) {
  const musicRef = useRef<HTMLInputElement>(null);
  const set = (partial: Partial<EffectsConfig>) => onChange({ ...effects, ...partial });

  return (
    <div className="space-y-2">
      <div className="flex items-center gap-2 mb-3">
        <Settings2 size={16} className="text-gray-500 dark:text-gray-400" />
        <h3 className="text-sm font-semibold text-gray-900 dark:text-gray-100">Efeitos e Ajustes</h3>
        <span className="text-xs text-gray-400 dark:text-gray-600">Ative e clique ▾ para configurar</span>
      </div>

      {/* Silence cut */}
      <EffectsSection title="Cortar Silêncios e Respirações" icon={<Scissors size={14} />}
        enabled={effects.silenceCut.enabled}
        onToggle={() => set({ silenceCut: { ...effects.silenceCut, enabled: !effects.silenceCut.enabled } })}>
        <SliderField label="Pausa mínima para cortar (s)" value={effects.silenceCut.gap}
          min={0.1} max={2.0} step={0.1} format={v => `${v.toFixed(1)}s`}
          onChange={v => set({ silenceCut: { ...effects.silenceCut, gap: v } })} />
        <SliderField label="Margem ao redor da fala (s)" value={effects.silenceCut.pad}
          min={0} max={0.5} step={0.05} format={v => `${v.toFixed(2)}s`}
          onChange={v => set({ silenceCut: { ...effects.silenceCut, pad: v } })} />
      </EffectsSection>

      {/* Zoom */}
      <EffectsSection title="Zoom Dinâmico" icon={<ZoomIn size={14} />}
        enabled={effects.zoom.enabled}
        onToggle={() => set({ zoom: { ...effects.zoom, enabled: !effects.zoom.enabled } })}>
        <SliderField label="Intensidade do zoom" value={effects.zoom.intensity}
          min={0.02} max={0.3} step={0.01} format={v => `${Math.round(v * 100)}%`}
          onChange={v => set({ zoom: { ...effects.zoom, intensity: v } })} />
        <p className="text-xs text-gray-400 dark:text-gray-500">Enquadramento mais próximo — dá mais dinamismo ao vídeo</p>
      </EffectsSection>

      {/* Captions */}
      <EffectsSection title="Legendas Automáticas" icon={<MessageSquare size={14} />}
        enabled={effects.captions.enabled}
        onToggle={() => set({ captions: { ...effects.captions, enabled: !effects.captions.enabled } })}>
        <SliderField label="Tamanho da fonte" value={effects.captions.fontSize}
          min={16} max={72} step={2} format={v => `${v}px`}
          onChange={v => set({ captions: { ...effects.captions, fontSize: v } })} />
        <div className="space-y-1.5">
          <span className="text-xs text-gray-600 dark:text-gray-400">Cor do texto</span>
          <div className="flex items-center gap-2 flex-wrap">
            {["#FFFFFF", "#FFFF00", "#00FF00", "#FF4444", "#000000"].map(c => (
              <button key={c} onClick={() => set({ captions: { ...effects.captions, color: c } })}
                className={`w-6 h-6 rounded-full border-2 transition-transform ${effects.captions.color === c ? "border-indigo-500 scale-110" : "border-gray-300 dark:border-gray-600"}`}
                style={{ backgroundColor: c }} title={c} />
            ))}
            <input type="color" value={effects.captions.color}
              onChange={e => set({ captions: { ...effects.captions, color: e.target.value } })}
              className="w-6 h-6 rounded cursor-pointer" title="Cor personalizada" />
          </div>
        </div>
        <div className="space-y-1.5">
          <span className="text-xs text-gray-600 dark:text-gray-400">Posição</span>
          <div className="flex gap-2">
            {(["top", "middle", "bottom"] as const).map(pos => (
              <button key={pos} onClick={() => set({ captions: { ...effects.captions, position: pos } })}
                className={`flex-1 py-1.5 rounded-lg text-xs font-medium border transition-colors ${
                  effects.captions.position === pos
                    ? "bg-indigo-600 text-white border-indigo-600"
                    : "border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800"}`}>
                {pos === "top" ? "Topo" : pos === "middle" ? "Centro" : "Baixo"}
              </button>
            ))}
          </div>
        </div>
      </EffectsSection>

      {/* Music */}
      <EffectsSection title="Música de Fundo" icon={<Music size={14} />}
        enabled={effects.music.enabled}
        onToggle={() => set({ music: { ...effects.music, enabled: !effects.music.enabled } })}>
        <div className="space-y-1.5">
          <span className="text-xs text-gray-600 dark:text-gray-400">Arquivo de música (MP3 / WAV)</span>
          <input ref={musicRef} type="file" accept="audio/*" className="hidden"
            onChange={e => { const f = e.target.files?.[0]; if (f) onMusicFile(f); }} />
          <button onClick={() => musicRef.current?.click()}
            className="w-full px-3 py-2 rounded-lg border border-dashed border-gray-300 dark:border-gray-600 text-xs text-left text-gray-500 dark:text-gray-400 hover:border-indigo-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
            {musicFile ? `✓ ${musicFile.name}` : "Clique para selecionar..."}
          </button>
        </div>
        <SliderField label="Volume da música" value={effects.music.volume}
          min={1} max={80} step={1} format={v => `${v}%`}
          onChange={v => set({ music: { ...effects.music, volume: v } })} />
        <p className="text-xs text-gray-400 dark:text-gray-500">A música é mixada em loop até o vídeo terminar</p>
      </EffectsSection>
    </div>
  );
}

// ─── Recent Videos ──────────────────────────────────────────────────────────

interface RecentJob {
  jobId: string;
  filename: string;
  createdAt: string | null;
  hasTranscription: boolean;
  hasAnalysis: boolean;
  hasEdited: boolean;
  thumbnailUrl: string | null;
}

function RecentVideos({ onRestore }: {
  onRestore: (jobId: string, analysis: Analysis | null, segments: any[]) => void;
}) {
  const [jobs, setJobs] = React.useState<RecentJob[]>([]);
  const [restoring, setRestoring] = React.useState<string | null>(null);
  const [error, setError] = React.useState<string | null>(null);

  React.useEffect(() => {
    fetch(`${API_BASE}/jobs`)
      .then(r => r.json())
      .then(data => setJobs(data.jobs || []))
      .catch(() => {});
  }, []);

  if (jobs.length === 0) return null;

  const handleRestore = async (jobId: string) => {
    setRestoring(jobId); setError(null);
    try {
      const res = await fetch(`${API_BASE}/restore/${jobId}`);
      if (!res.ok) throw new Error("Job não encontrado no servidor.");
      const data = await res.json();
      onRestore(jobId, data.analysis, data.segments || []);
    } catch (err) {
      setError("Não foi possível restaurar. O servidor pode ter reiniciado — faça o upload novamente.");
    } finally {
      setRestoring(null);
    }
  };

  const fmt = (iso: string | null) => {
    if (!iso) return "";
    const d = new Date(iso);
    return d.toLocaleDateString("pt-BR") + " " + d.toLocaleTimeString("pt-BR", { hour: "2-digit", minute: "2-digit" });
  };

  return (
    <div className="space-y-3">
      <div className="flex items-center gap-2">
        <History size={15} className="text-gray-500 dark:text-gray-400" />
        <h3 className="text-sm font-semibold text-gray-700 dark:text-gray-300">Vídeos recentes</h3>
        <span className="text-xs text-gray-400 dark:text-gray-600">Clique para reutilizar sem re-upload</span>
      </div>

      {error && (
        <div className="flex items-center gap-2 p-3 rounded-lg bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-600 dark:text-red-400 text-xs">
          <AlertCircle size={13} className="flex-shrink-0" />{error}
        </div>
      )}

      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {jobs.map(job => (
          <button key={job.jobId} onClick={() => handleRestore(job.jobId)}
            disabled={!!restoring}
            className="flex items-center gap-3 p-3 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 hover:border-indigo-300 dark:hover:border-indigo-600 hover:bg-indigo-50/50 dark:hover:bg-indigo-500/5 transition-all text-left group disabled:opacity-60">
            {/* Thumbnail */}
            <div className="w-14 h-14 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-800 flex-shrink-0">
              {job.thumbnailUrl
                ? <img src={job.thumbnailUrl} alt="" className="w-full h-full object-cover" />
                : <div className="w-full h-full flex items-center justify-center text-gray-400"><Film size={20} /></div>}
            </div>
            {/* Info */}
            <div className="flex-1 min-w-0">
              <p className="text-xs font-semibold text-gray-900 dark:text-gray-100 truncate group-hover:text-indigo-700 dark:group-hover:text-indigo-300">
                {job.filename}
              </p>
              <p className="text-[10px] text-gray-400 dark:text-gray-600 mt-0.5">{fmt(job.createdAt)}</p>
              <div className="flex gap-1 mt-1.5 flex-wrap">
                {job.hasAnalysis && (
                  <span className="text-[10px] bg-green-100 dark:bg-green-500/20 text-green-700 dark:text-green-400 px-1.5 py-0.5 rounded-full">Analisado</span>
                )}
                {job.hasEdited && (
                  <span className="text-[10px] bg-indigo-100 dark:bg-indigo-500/20 text-indigo-700 dark:text-indigo-400 px-1.5 py-0.5 rounded-full">Editado</span>
                )}
                {!job.hasAnalysis && !job.hasEdited && (
                  <span className="text-[10px] bg-gray-100 dark:bg-gray-800 text-gray-500 dark:text-gray-400 px-1.5 py-0.5 rounded-full">Upload</span>
                )}
              </div>
            </div>
            {restoring === job.jobId
              ? <Loader2 size={14} className="animate-spin text-indigo-500 flex-shrink-0" />
              : <ChevronRight size={14} className="text-gray-300 dark:text-gray-600 group-hover:text-indigo-400 flex-shrink-0 transition-colors" />}
          </button>
        ))}
      </div>
    </div>
  );
}

// ─── Main Page ─────────────────────────────────────────────────────────────

export default function VideoEditorPage() {
  const [step, setStep]         = useState<Step>("upload");
  const [dragOver, setDragOver] = useState(false);
  const [selectedFile, setSelectedFile] = useState<File | null>(null);
  const [jobId, setJobId]       = useState<string | null>(null);
  const [analysis, setAnalysis] = useState<Analysis | null>(null);
  const [editingScene, setEditingScene] = useState<number | null>(null);
  const [editForm, setEditForm] = useState<Partial<Scene>>({});
  const [globalError, setGlobalError] = useState<string | null>(null);
  const [renderStatus, setRenderStatus] = useState<"idle" | "processing" | "done" | "error">("idle");
  const [renderProgress, setRenderProgress] = useState(0);
  const [renderLabel, setRenderLabel]       = useState("");
  const [effects, setEffects]   = useState<EffectsConfig>(DEFAULT_EFFECTS);
  const [musicFile, setMusicFile] = useState<File | null>(null);
  const [serverReady, setServerReady] = useState(isLocal);
  const fileInputRef = useRef<HTMLInputElement>(null);

  // Ping Render on mount so it wakes up before user clicks anything
  React.useEffect(() => {
    if (isLocal) return;
    const ping = async () => {
      for (let i = 0; i < 10; i++) {
        try {
          const ctrl = new AbortController();
          const t = setTimeout(() => ctrl.abort(), 5000);
          const r = await fetch(`${RENDER_ORIGIN}/api/health`, { signal: ctrl.signal });
          clearTimeout(t);
          if (r.ok) { setServerReady(true); return; }
        } catch {}
        await new Promise(r => setTimeout(r, 3000));
      }
      setServerReady(true); // give up waiting, let user try
    };
    ping();
  }, []);

  const [processingSteps, setProcessingSteps] = useState<ProcessingStep[]>([
    { id: "normalize", label: "Normalizando vídeo",       icon: Film,  status: "pending" },
    { id: "transcribe", label: "Transcrevendo áudio",     icon: Mic,   status: "pending" },
    { id: "analyze",   label: "Analisando conteúdo com IA", icon: Brain, status: "pending" },
  ]);

  const updateStep = useCallback((id: ProcessingStepId, status: ProcessingStatus, error?: string) => {
    setProcessingSteps(prev => prev.map(s => s.id === id ? { ...s, status, error, percent: status === "done" ? 100 : s.percent } : s));
  }, []);

  const handleFileSelect = (file: File) => {
    if (!file.type.startsWith("video/")) { setGlobalError("Por favor, selecione um arquivo de vídeo (MP4 ou MOV)."); return; }
    setGlobalError(null);
    setSelectedFile(file);
  };

  const handleDrop = (e: React.DragEvent) => {
    e.preventDefault(); setDragOver(false);
    const file = e.dataTransfer.files[0];
    if (file) handleFileSelect(file);
  };

  const handleProcess = async () => {
    if (!selectedFile) return;
    setGlobalError(null);
    setStep("processing");
    setProcessingSteps(prev => prev.map(s => ({ ...s, status: "pending", error: undefined })));

    try {
      // 1. Upload
      const fd = new FormData();
      fd.append("video", selectedFile);
      const uploadRes = await fetch(`${API_BASE}/upload`, { method: "POST", body: fd });
      if (!uploadRes.ok) throw new Error("Falha no upload do vídeo.");
      const { jobId: currentJobId } = await uploadRes.json();
      setJobId(currentJobId);

      // 2. Normalize
      updateStep("normalize", "loading");
      const normalizeRes = await fetch(`${API_BASE}/normalize/${currentJobId}`, { method: "POST" });
      if (!normalizeRes.ok) {
        const err = await normalizeRes.json();
        updateStep("normalize", "error", err.error || "Erro na normalização."); return;
      }
      await new Promise<void>((resolve, reject) => {
        const poll = setInterval(async () => {
          try {
            const data = await fetch(`${API_BASE}/progress/${currentJobId}`).then(r => r.json());
            if (data.percent !== undefined)
              setProcessingSteps(prev => prev.map(s => s.id === "normalize" ? { ...s, percent: data.percent } : s));
            if (data.status === "done")   { clearInterval(poll); resolve(); }
            else if (data.status === "error") { clearInterval(poll); reject(new Error(data.error || "Erro na normalização.")); }
          } catch { clearInterval(poll); reject(new Error("Falha ao verificar progresso.")); }
        }, 1500);
      }).catch(err => { updateStep("normalize", "error", (err as Error).message); throw err; });
      updateStep("normalize", "done");

      // 3. Transcribe
      updateStep("transcribe", "loading");
      const transcribeRes = await fetch(`${API_BASE}/transcribe/${currentJobId}`, { method: "POST" });
      if (!transcribeRes.ok) {
        // Transcription failure is non-fatal — continue with empty segments
        console.warn("Transcription failed, continuing with empty segments");
        updateStep("transcribe", "done");
      } else {
        updateStep("transcribe", "done");
      }

      // 4. Analyze
      updateStep("analyze", "loading");
      const analyzeRes = await fetch(`${API_BASE}/analyze/${currentJobId}`, { method: "POST" });
      if (!analyzeRes.ok) {
        const err = await analyzeRes.json();
        updateStep("analyze", "error", err.error || "Erro na análise."); return;
      }
      const analysisData: Analysis = await analyzeRes.json();
      updateStep("analyze", "done");
      setAnalysis(analysisData);
      setTimeout(() => setStep("review"), 600);
    } catch (err: unknown) {
      setGlobalError(err instanceof Error ? err.message : "Erro desconhecido.");
      setStep("upload");
    }
  };

  const handleEditSave = () => {
    if (editingScene === null || !analysis) return;
    setAnalysis({ ...analysis, scenes: analysis.scenes.map(s => s.id === editingScene ? { ...s, ...editForm } : s) });
    setEditingScene(null); setEditForm({});
  };

  const openEdit = (scene: Scene) => {
    setEditingScene(scene.id);
    setEditForm({ title: scene.title, subtitle: scene.subtitle, type: scene.type });
  };

  const handleRender = async () => {
    if (!jobId) return;
    setRenderStatus("processing"); setRenderProgress(0); setRenderLabel("Iniciando...");
    try {
      // Upload music if needed
      if (effects.music.enabled && musicFile) {
        setRenderLabel("Enviando música...");
        const fd = new FormData();
        fd.append("music", musicFile);
        await fetch(`${API_BASE}/music/${jobId}`, { method: "POST", body: fd });
      }

      const res = await fetch(`${API_BASE}/render/${jobId}`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ effects }),
      });
      if (!res.ok) throw new Error("Falha ao iniciar renderização.");

      await new Promise<void>((resolve, reject) => {
        const poll = setInterval(async () => {
          try {
            const data = await fetch(`${API_BASE}/render-progress/${jobId}`).then(r => r.json());
            if (data.step === "render") {
              setRenderProgress(data.percent ?? 0);
              if (data.label) setRenderLabel(data.label);
              if (data.status === "done")  { clearInterval(poll); setRenderStatus("done"); resolve(); }
              else if (data.status === "error") { clearInterval(poll); reject(new Error(data.error || "Erro.")); }
            }
          } catch { clearInterval(poll); reject(new Error("Falha ao verificar progresso.")); }
        }, 1500);
      });
    } catch (err: unknown) {
      setRenderStatus("error");
      setRenderLabel(err instanceof Error ? err.message : "Erro desconhecido.");
    }
  };

  const handleReset = () => {
    setStep("upload"); setSelectedFile(null); setJobId(null); setAnalysis(null);
    setEditingScene(null); setGlobalError(null); setRenderStatus("idle");
    setRenderProgress(0); setMusicFile(null); setEffects(DEFAULT_EFFECTS);
    setProcessingSteps(prev => prev.map(s => ({ ...s, status: "pending", error: undefined })));
  };

  const handleRestore = useCallback((restoredJobId: string, restoredAnalysis: Analysis | null, restoredSegments: any[]) => {
    setJobId(restoredJobId);
    setGlobalError(null);
    setRenderStatus("idle");
    setRenderProgress(0);
    if (restoredAnalysis) {
      setAnalysis(restoredAnalysis);
      setStep("review");
    } else if (restoredSegments.length > 0) {
      // Has transcription but no analysis — run analyze only
      setStep("processing");
      setProcessingSteps(prev => prev.map(s => ({
        ...s,
        status: s.id === "normalize" ? "done" : s.id === "transcribe" ? "done" : "loading",
      })));
      fetch(`${API_BASE}/analyze/${restoredJobId}`, { method: "POST" })
        .then(r => r.json())
        .then((data: Analysis) => {
          setAnalysis(data);
          setProcessingSteps(prev => prev.map(s => ({ ...s, status: "done" })));
          setTimeout(() => setStep("review"), 600);
        })
        .catch(err => {
          setGlobalError("Erro ao reanalisar: " + (err instanceof Error ? err.message : String(err)));
          setStep("upload");
        });
    } else {
      // Nothing processed yet — go to processing from start
      setGlobalError("Este vídeo ainda não foi processado. Clique em 'Processar Vídeo' para analisar.");
      setStep("upload");
    }
  }, []);

  // ─── Render ──────────────────────────────────────────────────────────────

  return (
    <div className="max-w-6xl mx-auto px-4 py-8 space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div>
          <h1 className="text-2xl font-bold text-[#1A1A1A] dark:text-gray-100">Editor de Vídeo IA</h1>
          <p className="text-sm text-gray-500 dark:text-gray-400 mt-1">
            Corta silêncios, adiciona legendas, zoom e música automaticamente.
          </p>
        </div>
        {step !== "upload" && (
          <button onClick={handleReset}
            className="flex items-center gap-2 px-4 py-2 rounded-xl border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium transition-colors">
            <X size={16} />Novo vídeo
          </button>
        )}
      </div>

      {/* Step indicator */}
      <div className="flex items-center gap-2">
        {(["upload", "processing", "review"] as Step[]).map((s, i) => (
          <React.Fragment key={s}>
            <div className={`flex items-center gap-2 px-3 py-1.5 rounded-lg text-sm font-medium transition-colors ${
              step === s ? "bg-indigo-50 dark:bg-indigo-500/20 text-indigo-700 dark:text-indigo-300"
              : i < ["upload", "processing", "review"].indexOf(step) ? "text-green-600 dark:text-green-400"
              : "text-gray-400 dark:text-gray-600"}`}>
              {i < ["upload", "processing", "review"].indexOf(step)
                ? <CheckCircle size={14} />
                : <span className="w-4 h-4 rounded-full border-2 border-current flex items-center justify-center text-xs">{i + 1}</span>}
              {s === "upload" ? "Upload" : s === "processing" ? "Processando" : "Revisão & Efeitos"}
            </div>
            {i < 2 && <ChevronRight size={14} className="text-gray-300 dark:text-gray-700" />}
          </React.Fragment>
        ))}
      </div>

      {globalError && (
        <div className="flex items-center gap-3 p-4 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 text-sm">
          <AlertCircle size={18} className="flex-shrink-0" />{globalError}
        </div>
      )}

      {/* ── UPLOAD ── */}
      {step === "upload" && (
        <div className="space-y-6">
          <div onDrop={handleDrop}
            onDragOver={e => { e.preventDefault(); setDragOver(true); }}
            onDragLeave={() => setDragOver(false)}
            onClick={() => fileInputRef.current?.click()}
            className={`relative flex flex-col items-center justify-center gap-4 p-16 rounded-2xl border-2 border-dashed cursor-pointer transition-all ${
              dragOver      ? "border-indigo-500 bg-indigo-50 dark:bg-indigo-500/10"
              : selectedFile ? "border-green-400 dark:border-green-500 bg-green-50 dark:bg-green-500/10"
              : "border-gray-200 dark:border-gray-800 bg-[#F8F9FA] dark:bg-gray-900 hover:border-indigo-300 dark:hover:border-indigo-700"}`}>
            <input ref={fileInputRef} type="file" accept="video/mp4,video/quicktime,video/*" className="hidden"
              onChange={e => { const f = e.target.files?.[0]; if (f) handleFileSelect(f); }} />
            <div className={`w-16 h-16 rounded-2xl flex items-center justify-center ${selectedFile ? "bg-green-100 dark:bg-green-500/20 text-green-600 dark:text-green-400" : "bg-indigo-100 dark:bg-indigo-500/20 text-indigo-600 dark:text-indigo-400"}`}>
              {selectedFile ? <CheckCircle size={32} /> : <Upload size={32} />}
            </div>
            {selectedFile ? (
              <div className="text-center">
                <p className="text-base font-semibold text-gray-900 dark:text-gray-100">{selectedFile.name}</p>
                <p className="text-sm text-gray-500 dark:text-gray-400 mt-1">{(selectedFile.size / 1024 / 1024).toFixed(1)} MB — Clique para trocar</p>
              </div>
            ) : (
              <div className="text-center">
                <p className="text-base font-semibold text-gray-900 dark:text-gray-100">Arraste seu vídeo aqui</p>
                <p className="text-sm text-gray-500 dark:text-gray-400 mt-1">ou clique para selecionar — MP4 ou MOV</p>
              </div>
            )}
          </div>
          <button onClick={handleProcess} disabled={!selectedFile || !serverReady}
            className="w-full flex items-center justify-center gap-2 px-6 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold text-base transition-colors">
            {!serverReady
              ? <><Loader2 size={20} className="animate-spin" />Conectando ao servidor... aguarde</>
              : <><Play size={20} />Processar Vídeo com IA</>}
          </button>

          <RecentVideos onRestore={handleRestore} />
        </div>
      )}

      {/* ── PROCESSING ── */}
      {step === "processing" && (
        <div className="space-y-4 max-w-lg mx-auto">
          <p className="text-sm text-gray-500 dark:text-gray-400 text-center mb-6">
            A IA está analisando seu vídeo. Pode levar alguns minutos.
          </p>
          {processingSteps.map(s => <ProcessingStepItem key={s.id} step={s} />)}
          {processingSteps.some(s => s.status === "error") && (
            <button onClick={handleReset}
              className="w-full mt-2 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-800 text-gray-600 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm font-medium transition-colors">
              Voltar e tentar novamente
            </button>
          )}
        </div>
      )}

      {/* ── REVIEW ── */}
      {step === "review" && analysis && jobId && (
        <div className="space-y-6">

          {/* ═══ RESULTADO: Prévia do vídeo editado ═══ */}
          {renderStatus === "done" && (
            <div className="space-y-4">
              {/* Banner de sucesso */}
              <div className="flex items-center gap-3 p-4 rounded-xl bg-green-50 dark:bg-green-500/10 border border-green-200 dark:border-green-500/20">
                <CheckCircle size={20} className="text-green-600 dark:text-green-400 flex-shrink-0" />
                <div className="flex-1">
                  <p className="text-sm font-semibold text-green-800 dark:text-green-300">Vídeo editado com sucesso!</p>
                  <p className="text-xs text-green-600 dark:text-green-400 mt-0.5">Assista a prévia completa abaixo antes de baixar.</p>
                </div>
              </div>

              {/* Player do vídeo editado — destaque principal */}
              <div className="rounded-2xl overflow-hidden bg-black shadow-2xl">
                <video
                  key="edited-result"
                  controls
                  className="w-full max-h-[70vh] object-contain"
                  src={`${API_BASE}/edited/${jobId}`}
                />
              </div>

              {/* Ações pós-render */}
              <div className="flex flex-wrap gap-3">
                <a href={`${API_BASE}/edited/${jobId}`} download="video-editado.mp4"
                  className="flex items-center gap-2 px-6 py-3 rounded-xl bg-green-600 hover:bg-green-700 text-white font-semibold text-sm transition-colors shadow-sm">
                  <Download size={16} />Baixar Vídeo Editado
                </a>
                <button onClick={() => { setRenderStatus("idle"); setRenderProgress(0); }}
                  className="flex items-center gap-2 px-5 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 font-semibold text-sm transition-colors">
                  <Settings2 size={16} />Ajustar Efeitos e Renderizar Novamente
                </button>
                <a href={`${API_BASE}/video/${jobId}`} download
                  className="flex items-center gap-2 px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400 hover:bg-gray-50 dark:hover:bg-gray-800 text-sm transition-colors">
                  <Download size={14} />Original
                </a>
              </div>
            </div>
          )}

          {/* ═══ CONFIGURAÇÃO: antes/durante o render ═══ */}
          {renderStatus !== "done" && (
            <>
              {/* Info bar */}
              <div className="flex flex-wrap items-center gap-3 p-4 rounded-xl bg-[#F8F9FA] dark:bg-gray-900 border border-gray-200 dark:border-gray-800">
                <div className="flex items-center gap-2">
                  <span className="text-xs text-gray-500 dark:text-gray-400">Formato:</span>
                  <span className="text-sm font-semibold text-gray-900 dark:text-gray-100">{NARRATIVE_FORMAT_LABELS[analysis.narrativeFormat] || analysis.narrativeFormat}</span>
                </div>
                <span className="text-gray-300 dark:text-gray-700">|</span>
                <div className="flex items-center gap-2">
                  <span className="text-xs text-gray-500 dark:text-gray-400">Cenas:</span>
                  <span className="text-sm font-semibold text-gray-900 dark:text-gray-100">{analysis.scenes.length}</span>
                </div>
                <div className="flex items-center gap-2 ml-auto">
                  {Object.entries(analysis.colorPalette).map(([key, hex]) => (
                    <div key={key} className="w-5 h-5 rounded-full border border-white dark:border-gray-800 shadow-sm" style={{ backgroundColor: hex }} title={`${key}: ${hex}`} />
                  ))}
                </div>
              </div>

              {/* Video original + Cenas */}
              <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
                <div className="space-y-3">
                  <h2 className="text-sm font-semibold text-gray-700 dark:text-gray-300">Pré-visualização (original)</h2>
                  <div className="rounded-xl overflow-hidden bg-black aspect-video">
                    <video controls className="w-full h-full object-contain" src={`${API_BASE}/video/${jobId}`} />
                  </div>
                  <CutTimeline jobId={jobId} apiBase={API_BASE} />
                </div>

                <div className="space-y-3">
                  <h2 className="text-sm font-semibold text-gray-700 dark:text-gray-300">Cenas detectadas ({analysis.scenes.length})</h2>
                  <div className="space-y-2 max-h-[420px] overflow-y-auto pr-1">
                    {analysis.scenes.map(scene => (
                      <div key={scene.id} className="p-4 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 space-y-2">
                        {editingScene === scene.id ? (
                          <div className="space-y-3">
                            <div className="flex items-center justify-between">
                              <span className="text-xs font-semibold text-gray-500 dark:text-gray-400">Editando cena {scene.id}</span>
                              <button onClick={() => setEditingScene(null)} className="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200"><X size={14} /></button>
                            </div>
                            <div>
                              <label className="block text-xs text-gray-500 dark:text-gray-400 mb-1">Tipo</label>
                              <select value={editForm.type} onChange={e => setEditForm({ ...editForm, type: e.target.value as Scene["type"] })}
                                className="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500">
                                {(Object.keys(SCENE_TYPE_LABELS) as Scene["type"][]).map(t => (
                                  <option key={t} value={t}>{t} — {SCENE_TYPE_LABELS[t]}</option>
                                ))}
                              </select>
                            </div>
                            <div>
                              <label className="block text-xs text-gray-500 dark:text-gray-400 mb-1">Título</label>
                              <input type="text" value={editForm.title || ""} onChange={e => setEditForm({ ...editForm, title: e.target.value })}
                                className="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                            </div>
                            <div>
                              <label className="block text-xs text-gray-500 dark:text-gray-400 mb-1">Subtítulo (opcional)</label>
                              <input type="text" value={editForm.subtitle || ""} onChange={e => setEditForm({ ...editForm, subtitle: e.target.value })}
                                className="w-full px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-gray-100 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                            </div>
                            <div className="flex gap-2">
                              <button onClick={handleEditSave} className="flex-1 px-3 py-2 rounded-lg bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-semibold transition-colors">Salvar</button>
                              <button onClick={() => setEditingScene(null)} className="px-3 py-2 rounded-lg border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-400 text-xs font-semibold hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors">Cancelar</button>
                            </div>
                          </div>
                        ) : (
                          <div className="flex items-start gap-3">
                            <div className="flex-shrink-0 w-7 h-7 rounded-lg bg-gray-100 dark:bg-gray-800 flex items-center justify-center text-sm font-bold text-gray-500 dark:text-gray-400">{scene.id}</div>
                            <div className="flex-1 min-w-0">
                              <div className="flex items-center gap-2 flex-wrap mb-1">
                                <SceneTypeBadge type={scene.type} />
                                {scene.icon && <span className="text-base">{scene.icon}</span>}
                              </div>
                              <p className="text-sm font-semibold text-gray-900 dark:text-gray-100 truncate">{scene.title}</p>
                              {scene.subtitle && <p className="text-xs text-gray-500 dark:text-gray-400 mt-0.5 truncate">{scene.subtitle}</p>}
                              <p className="text-xs text-gray-400 dark:text-gray-600 mt-1">Palavra #{scene.startLeg} · {scene.duration}s</p>
                            </div>
                            <button onClick={() => openEdit(scene)}
                              className="flex-shrink-0 p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 transition-colors" title="Editar cena">
                              <Edit2 size={14} />
                            </button>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              </div>

              {/* Effects Panel */}
              <div className="p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-[#F8F9FA] dark:bg-gray-900/50">
                <EffectsPanel effects={effects} onChange={setEffects} musicFile={musicFile} onMusicFile={setMusicFile} />
              </div>

              {/* Music warning */}
              {effects.music.enabled && !musicFile && (
                <div className="flex items-center gap-2 p-3 rounded-lg bg-yellow-50 dark:bg-yellow-500/10 border border-yellow-200 dark:border-yellow-500/20 text-yellow-700 dark:text-yellow-400 text-xs">
                  <AlertCircle size={14} className="flex-shrink-0" />
                  Música de fundo ativa mas nenhum arquivo selecionado — selecione um MP3 no painel acima.
                </div>
              )}

              {/* Render controls */}
              <div className="p-5 rounded-xl border border-gray-200 dark:border-gray-800 bg-white dark:bg-gray-900 space-y-4">
                <div>
                  <h2 className="text-sm font-semibold text-gray-900 dark:text-gray-100">Exportar Vídeo com Efeitos</h2>
                  <p className="text-xs text-gray-500 dark:text-gray-400 mt-1">Configure os efeitos acima e clique para renderizar. Você poderá assistir antes de baixar.</p>
                </div>

                {renderStatus === "processing" && (
                  <div className="space-y-2">
                    <div className="flex items-center justify-between text-xs text-indigo-600 dark:text-indigo-400">
                      <span>{renderLabel || "Processando..."}</span>
                      <span>{renderProgress}%</span>
                    </div>
                    <div className="h-2 bg-gray-100 dark:bg-gray-800 rounded-full overflow-hidden">
                      <div className="h-full bg-indigo-500 rounded-full transition-all duration-500" style={{ width: `${renderProgress}%` }} />
                    </div>
                  </div>
                )}

                {renderStatus === "error" && (
                  <div className="flex items-center gap-3 p-3 rounded-xl bg-red-50 dark:bg-red-500/10 border border-red-200 dark:border-red-500/20 text-red-700 dark:text-red-400 text-sm">
                    <AlertCircle size={16} className="flex-shrink-0" />{renderLabel || "Erro na renderização."}
                  </div>
                )}

                <div className="flex flex-wrap gap-3">
                  <button onClick={handleRender} disabled={renderStatus === "processing"}
                    className="flex items-center gap-2 px-5 py-3 rounded-xl bg-indigo-600 hover:bg-indigo-700 disabled:opacity-60 disabled:cursor-not-allowed text-white font-semibold text-sm transition-colors">
                    {renderStatus === "processing"
                      ? <><Loader2 size={16} className="animate-spin" />Editando vídeo...</>
                      : <><Play size={16} />Editar e Exportar Vídeo</>}
                  </button>
                  <a href={`${API_BASE}/video/${jobId}`} download
                    className="flex items-center gap-2 px-5 py-3 rounded-xl border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 font-semibold text-sm transition-colors">
                    <Download size={16} />Baixar Original
                  </a>
                </div>
              </div>
            </>
          )}
        </div>
      )}
    </div>
  );
}
